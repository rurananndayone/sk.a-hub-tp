-- [[ 👑 SK.a HUB - ARCADE MONOLITH 👑 ]]
-- 見た目：Arcade Style / 名前：SK.a HUB / エフェクト：NONE

local p = game:GetService("Players").LocalPlayer
local rs = game:GetService("RunService")
local uis = game:GetService("UserInputService")
local ts = game:GetService("TweenService")

local f = {speed = false, esp = false, infjump = false} 
local LIMIT_SPEED, JUMP_POWER, TP_DELAY = 30.8, 50, 0.5
local savedPosition, visualMarker = nil, nil
local ui_visible = true
local isTeleporting = false

local BLUE_ACCENT = Color3.fromRGB(0, 120, 255)
local BG_DARK = Color3.fromRGB(0, 0, 0)

-- 旧UI掃除
for _, v in pairs(p.PlayerGui:GetChildren()) do
    if v.Name:find("SKa_HUB_") or v.Name:find("SakanaHub_") or v.Name == "SakanaCenterCharge" then v:Destroy() end
end

-- --- ★ Arcadeテキスト生成関数 ---
local function SetArcadeStyle(obj, text, size, color)
    obj.Font = Enum.Font.Arcade
    obj.Text = "<b>" .. text .. "</b>"
    obj.TextSize = size or 14
    obj.TextColor3 = color or Color3.new(1, 1, 1)
    obj.RichText = true
end

-- --- ★ フレーム生成 (Arcade Style) ---
local function createBase(name, size, pos)
    local sg = Instance.new("ScreenGui", p.PlayerGui); sg.Name = "SKa_HUB_"..name; sg.ResetOnSpawn = false
    local fr = Instance.new("Frame", sg); fr.Size = size; fr.Position = pos
    fr.BackgroundColor3 = BG_DARK; fr.BackgroundTransparency = 0.4; fr.Active, fr.Draggable = true, true
    Instance.new("UICorner", fr).CornerRadius = UDim.new(0, 8)
    local stroke = Instance.new("UIStroke", fr); stroke.Color = BLUE_ACCENT; stroke.Thickness = 2.5
    return fr, sg
end

local main_fr = createBase("Main", UDim2.new(0, 240, 0, 220), UDim2.new(0.05, 0, 0.3, 0))
local tp_fr = createBase("TP", UDim2.new(0, 260, 0, 180), UDim2.new(0.75, 0, 0.65, 0))
local slide_fr = createBase("Sliders", UDim2.new(0, 260, 0, 260), UDim2.new(0.75, 0, 0.25, 0))

-- センターチャージバー (Arcade Style)
local csg = Instance.new("ScreenGui", p.PlayerGui); csg.Name = "SakanaCenterCharge"; csg.ResetOnSpawn = false
local cbase = Instance.new("Frame", csg); cbase.Size = UDim2.new(0, 300, 0, 15); cbase.Position = UDim2.new(0.5, -150, 0.7, 0)
cbase.BackgroundColor3 = BG_DARK; cbase.BackgroundTransparency = 0.5; cbase.Visible = false
Instance.new("UIStroke", cbase).Color = BLUE_ACCENT; local cfill = Instance.new("Frame", cbase); cfill.Size = UDim2.new(0, 0, 1, 0); cfill.BackgroundColor3 = BLUE_ACCENT

-- タイトルロゴ
local function createTitle(parent, text)
    local l = Instance.new("TextLabel", parent); l.Size = UDim2.new(1, 0, 0, 40); l.BackgroundTransparency = 1
    SetArcadeStyle(l, text, 18, BLUE_ACCENT); return l
end
createTitle(main_fr, "SK.a HUB"); createTitle(tp_fr, "TP System"); createTitle(slide_fr, "Tweak Settings")

-- --- ★ ボタン生成 (Arcade Style) ---
local function createBtn(parent, txt, y, id)
    local btn = Instance.new("TextButton", parent)
    btn.Size = UDim2.new(0, 216, 0, 35); btn.Position = UDim2.new(0, 12, 0, y)
    btn.BackgroundColor3 = Color3.fromRGB(30, 30, 30); btn.BackgroundTransparency = 0.6; btn.BorderSizePixel = 0
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)
    local stroke = Instance.new("UIStroke", btn); stroke.Color = BLUE_ACCENT; stroke.Thickness = 1.5
    SetArcadeStyle(btn, txt .. ": OFF", 14)
    
    if id then
        btn.MouseButton1Click:Connect(function()
            f[id] = not f[id]
            SetArcadeStyle(btn, txt .. (f[id] and ": ON" or ": OFF"), 14)
            btn.BackgroundColor3 = f[id] and BLUE_ACCENT or Color3.fromRGB(30, 30, 30)
            btn.BackgroundTransparency = f[id] and 0.4 or 0.6
        end)
    end
    return btn
end

createBtn(main_fr, "SPEED HACK", 55, "speed")
createBtn(main_fr, "PLAYER ESP", 105, "esp")
createBtn(main_fr, "INF JUMP", 155, "infjump")

local markBtn = createBtn(tp_fr, "SET COORD", 55); SetArcadeStyle(markBtn, "SET COORD:key J", 13)
local goBtn = createBtn(tp_fr, "EXECUTE TP", 110); SetArcadeStyle(goBtn, "EXECUTE TP:key L", 13)

-- --- ★ TP / 警告音同期 ---
local function playBeep()
    local s = Instance.new("Sound", game:GetService("SoundService")); s.SoundId = "rbxassetid://1354084365"; s.TimePosition = 0.04; s.Volume = 5; s.Pitch = 1.3; s:Play(); game:GetService("Debris"):AddItem(s, 0.4)
end

goBtn.MouseButton1Click:Connect(function()
    if savedPosition and not isTeleporting then
        isTeleporting = true; cbase.Visible = true; cfill.Size = UDim2.new(0, 0, 1, 0)
        local tween = ts:Create(cfill, TweenInfo.new(TP_DELAY, Enum.EasingStyle.Linear), {Size = UDim2.new(1, 0, 1, 0)})
        tween:Play()
        task.spawn(function() for i = 1, 8 do playBeep() task.wait(TP_DELAY / 8) end end)
        tween.Completed:Connect(function()
            local hrp = p.Character and p.Character:FindFirstChild("HumanoidRootPart")
            if hrp then hrp.CFrame = CFrame.new(savedPosition + Vector3.new(0, 3, 0)) end
            task.wait(0.1); cbase.Visible = false; isTeleporting = false
        end)
    end
end)

markBtn.MouseButton1Click:Connect(function()
    local hrp = p.Character and p.Character:FindFirstChild("HumanoidRootPart")
    if hrp then
        savedPosition = hrp.Position; if visualMarker then visualMarker:Destroy() end
        visualMarker = Instance.new("Part", workspace); visualMarker.Size = Vector3.new(4, 0.1, 4); visualMarker.Position = savedPosition - Vector3.new(0, 2.8, 0); visualMarker.Anchored, visualMarker.CanCollide = true, false; visualMarker.Material = Enum.Material.Neon; visualMarker.Color = BLUE_ACCENT; visualMarker.Shape = Enum.PartType.Cylinder; visualMarker.Rotation = Vector3.new(0, 0, 90)
    end
end)

-- --- ★ スライダー ---
local function setupSlider(parent, y, label, minVal, maxVal, currentVal, update)
    local fr = Instance.new("Frame", parent); fr.Size = UDim2.new(0.9, 0, 0, 50); fr.Position = UDim2.new(0.05, 0, 0, y); fr.BackgroundTransparency = 1
    local lbl = Instance.new("TextLabel", fr); lbl.Size = UDim2.new(1, 0, 0, 20); lbl.BackgroundTransparency = 1; SetArcadeStyle(lbl, label .. currentVal, 12)
    local bar = Instance.new("Frame", fr); bar.Size = UDim2.new(0.8, 0, 0, 3); bar.Position = UDim2.new(0.1, 0, 0.7, 0); bar.BackgroundColor3 = Color3.new(0,0,0); local dot = Instance.new("TextButton", bar); dot.Size = UDim2.new(0, 14, 0, 14); dot.Position = UDim2.new((currentVal-minVal)/(maxVal-minVal), -7, 0.5, -7); dot.BackgroundColor3 = BLUE_ACCENT; dot.Text = ""; Instance.new("UICorner", dot)
    local drag = false; dot.MouseButton1Down:Connect(function() drag = true end)
    uis.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then drag = false end end)
    rs.Heartbeat:Connect(function() if drag then local rel = math.clamp((uis:GetMouseLocation().X - bar.AbsolutePosition.X) / bar.AbsoluteSize.X, 0, 1); dot.Position = UDim2.new(rel, -7, 0.5, -7); local val = (maxVal > 10) and math.floor(minVal + (rel * (maxVal - minVal))) or math.floor((minVal + (rel * (maxVal - minVal))) * 10) / 10; SetArcadeStyle(lbl, label .. val, 12); update(val) end end)
end
setupSlider(slide_fr, 55, "SPD: ", 16, 150, LIMIT_SPEED, function(v) LIMIT_SPEED = v end)
setupSlider(slide_fr, 115, "JMP: ", 50, 250, JUMP_POWER, function(v) JUMP_POWER = v end)
setupSlider(slide_fr, 175, "DLY: ", 0, 2.0, TP_DELAY, function(v) TP_DELAY = v end)

-- --- ★ キーバインド / ループ ---
uis.InputBegan:Connect(function(input, g)
    if g then return end
    if input.KeyCode == Enum.KeyCode.Insert then ui_visible = not ui_visible; for _, v in pairs(p.PlayerGui:GetChildren()) do if v.Name:find("SKa_HUB_") then v.Enabled = ui_visible end end
    elseif input.KeyCode == Enum.KeyCode.J then markBtn.MouseButton1Click:Fire()
    elseif input.KeyCode == Enum.KeyCode.L then goBtn.MouseButton1Click:Fire() end
end)

rs.PreRender:Connect(function()
    local char = p.Character; local hum = char and char:FindFirstChild("Humanoid"); local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if f.speed and hrp and hum and hum.MoveDirection.Magnitude > 0 then hrp.AssemblyLinearVelocity = Vector3.new(hum.MoveDirection.X * LIMIT_SPEED, hrp.AssemblyLinearVelocity.Y, hum.MoveDirection.Z * LIMIT_SPEED) end
end)
uis.JumpRequest:Connect(function() if f.infjump then local hrp = p.Character and p.Character:FindFirstChild("HumanoidRootPart") if hrp then hrp.AssemblyLinearVelocity = Vector3.new(hrp.AssemblyLinearVelocity.X, JUMP_POWER, hrp.AssemblyLinearVelocity.Z) end end end)

task.spawn(function()
    while task.wait(0.3) do
        if f.esp then for _, plr in pairs(game.Players:GetPlayers()) do if plr ~= p and plr.Character then local hl = plr.Character:FindFirstChild("SKa_ESP") or Instance.new("Highlight", plr.Character); hl.Name = "SKa_ESP"; hl.FillColor = BLUE_ACCENT; hl.OutlineColor = Color3.new(1,1,1); hl.FillTransparency = 0.5 end end
        else for _, plr in pairs(game.Players:GetPlayers()) do if plr.Character and plr.Character:FindFirstChild("SKa_ESP") then plr.Character.SKa_ESP:Destroy() end end end
    end
end)
